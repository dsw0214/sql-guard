# SQLGuard Docker environment template
# Copy this file to .env and adjust values for your environment.

# Backend service bind
SQLGUARD_HOST=0.0.0.0
SQLGUARD_PORT=8000

# AI provider: ollama or openai
SQLGUARD_AI_PROVIDER=ollama

# Ollama settings
# macOS/Windows Docker Desktop can use host.docker.internal
# Linux can replace with host IP (for example 172.17.0.1 or LAN IP)
SQLGUARD_OLLAMA_BASE_URL=http://host.docker.internal:11434
SQLGUARD_OLLAMA_MODEL=qwen3.5:9b
SQLGUARD_OLLAMA_HTTP_TIMEOUT=300

# Optional OpenAI-compatible settings (used when SQLGUARD_AI_PROVIDER=openai)
# SQLGUARD_AI_API_KEY=
# SQLGUARD_AI_BASE_URL=https://api.openai.com/v1
# SQLGUARD_AI_MODEL=gpt-4o-mini
# SQLGUARD_AI_HTTP_TIMEOUT=30
